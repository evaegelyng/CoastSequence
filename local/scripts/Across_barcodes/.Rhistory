saveRDS(venn_wat,'../../Plots/Venn/COI_70_wat.rds')
wat<-within(wat,rm(sc))
# Subset to each salinity group
sed_3hab$sch<-paste(sed_3hab$sc,sed_3hab$habitat,sep="_")
sed_3hab$sal_group<-salinity$sal_group[match(sed_3hab$sch,rownames(salinity))]
low<-sed_3hab[sed_3hab$sal_group=="1",]
med<-sed_3hab[sed_3hab$sal_group=="2",]
high<-sed_3hab[sed_3hab$sal_group=="3",]
low<-within(low,rm(habitat,sc,sch,sal_group))
med<-within(med,rm(habitat,sc,sch,sal_group))
high<-within(high,rm(habitat,sc,sch,sal_group))
# Make species list for each salinity group
low<-low[,colSums(low)>0]
low_sp<-colnames(low)
med<-med[,colSums(med)>0]
med_sp<-colnames(med)
high<-high[,colSums(high)>0]
high_sp<-colnames(high)
sed_list <- list(Low = low_sp,Medium = med_sp,High = high_sp)
venn_sed <- ggeulerr(sed_list[1:3]) +
theme_bw(base_size = 14) + # For white background
theme(axis.title = element_blank(), axis.text = element_blank(), axis.ticks = element_blank()) +  # To remove axis text, titles and ticks
theme(panel.grid = element_blank()) + # To remove gridlines
theme(panel.border = element_blank()) + # To remove plot border
scale_fill_manual(values = c(Low = "red", Medium = "green", High = "blue"))  #Setting colors for categories
#+ guides(fill="none") # To remove legend for categories (these are shown with labels anyways)
venn_sed
saveRDS(venn_sed,"../../Plots/Venn/COI_sal_sed.rds")
knitr::opts_chunk$set(echo = TRUE)
