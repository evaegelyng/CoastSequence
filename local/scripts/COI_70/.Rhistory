ggplot(data = dat, aes(x = rich, group = habitat, fill=habitat)) +
geom_density(adjust=1.5, alpha=.4) +
scale_fill_viridis(discrete=TRUE) +
scale_color_viridis(discrete=TRUE) +
theme_ipsum() +
labs(y = "", x = "Richness", title = "Distribution of Raw Richness values", fill = "Habitat")
skewness(dat$rich)
dat$habitat <- as.factor(dat$habitat)
res_aov_rich_hab <- aov(rich ~ habitat,
data = dat)
summary(res_aov_rich_hab)
hist(res_aov_rich_hab$residuals)
qqPlot(res_aov_rich_hab$residuals, id = FALSE)
kruskal.test(rich ~ habitat,
data = dat)
dunn_res_hab <- dunnTest(rich ~ habitat,
data = dat,
method = "bonferroni"
)
dunn_res_hab
# First determine median richness for rock habitat
median(dat$rich[dat$habitat == "rocks"]) # 1898.5 OTUs
# Now calculate pairwise differences in median richness
pairs <- combn(unique(dat$habitat), 2, simplify = FALSE)
for (p in pairs) {
g1 <- dat$rich[dat$habitat == p[1]]
g2 <- dat$rich[dat$habitat == p[2]]
diff_medians <- median(g1) - median(g2)
cat(paste0(p[1], " vs ", p[2], ": median difference = ", diff_medians, "\n"))
}
