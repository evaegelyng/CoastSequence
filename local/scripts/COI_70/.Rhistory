coi_sal <- readRDS("../../Plots/Scatter_rich/Salinity/COI_salinity_facet.rds")
pro_sal <- readRDS("../../Plots/Scatter_rich/Salinity/16S_salinity_facet.rds")
ggsave(file="../../Plots/Scatter_rich/Salinity/All_sal_facet.png",ggarrange(euk_sal,coi_sal,pro_sal,ncol=1,nrow=3,align="h",common.legend=TRUE),width=30,height=40,units="cm")
library(Hmsc)
fitTF_COI_sed <- readRDS("../../RDS/fitTF_COI_sed.rds")
VP <- computeVariancePartitioning(fitTF_COI_sed)
# Plot (quick overview)
plotVariancePartitioning(fitTF_COI_sed, VP = VP)
dim(VP$vals)
rownames(VP$vals)
vp_vals <- VP$vals   # components × species
# Average variance explained per component
mean_vp <- rowMeans(vp_vals)
mean_vp
mean_vp[c("Random: space", "Random: Time_d")]
# Identify components
space_name <- "Random: space"
time_name  <- "Random: Time_d"
# Everything else = fixed effects
fixed_effects <- setdiff(names(mean_vp), c(space_name, time_name))
# Aggregate
summary_simple <- data.frame(
Component = c("Fixed", "Time", "Space"),
Variance = c(
sum(mean_vp[fixed_effects]),
mean_vp[time_name],
mean_vp[space_name]
)
)
summary_simple
post <- getPostEstimate(fitTF_COI_sed, parName = "Lambda")
Lambda <- post$mean  # LF × species
# variance per LF (within space)
factor_var <- rowSums(Lambda^2)
# proportion within spatial component
prop_LF_within_space <- factor_var / sum(factor_var)
?getPostEstimate
space_var <- mean_vp[space_name]
prop_LF_total <- prop_LF_within_space * space_var
LF_names <- paste0("LF", 1:length(prop_LF_total))
LF_summary <- data.frame(
LF = LF_names,
Var_within_space = prop_LF_within_space,
Var_total = prop_LF_total
)
LF_summary
